#include<stdio.h>
#include<stdlib.h>
#include<math.h>
//

long int f(long double d);
long int power(int n);
int main()
{
    int n=0;
    long double d=0;
    scanf("%d %Lf",&n,&d);
    long double ld=(long double)power(n)*d;
    printf("%ld",f(ld));
    //printf("%ld",power(n));
    return 0;
}

long int power(int n)
{
    if(n==1)
        return 2;
    else 
        return 2*power(n-1);
}

long int f(long double d)
{
    double m=d-(int)d;
    if(m>=0.5)
        return floor(d)+1;
    else
        return floor(d);
}
