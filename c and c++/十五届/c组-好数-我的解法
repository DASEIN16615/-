#include <stdio.h>
#include <string.h>
#include <limits.h>
/*
算法练习-好数
*/
int judge(int *t,int counter);
int main() 
{
    int all=0;
    int n;
    scanf("%d", &n);
    for(int i=1;i<=n;i++)
    {
        int num=i;
        int temp=i;
        int counter=0;
        while(temp!=0)//计算位数
        {
            temp/=10;
            counter++;
        }
        int t[counter+1];
        for(int j=1;j<=counter;j++)//将每一位存入数组
        {
            t[j]=num%10;
            num/=10;
        }
        all+=judge(t,counter);//判断是否为好数，并累加结果
    }
    printf("%d\n",all);
    return 0;
}
int judge(int *t,int counter)
{
    for(int j=1;j<=counter;j++)
    {
        if(((j%2==1)&&(t[j]%2==1))||((j%2==0)&&(t[j]%2==0)))
        {
            continue;
        }
        else 
        {
            return 0;
        }
    }
    return 1;
}
