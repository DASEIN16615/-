#include<stdio.h>
#include<stdlib.h>

/*
思路：
定义结构体，包含接受的数和6的个数
计算6的个数加起来大于等于六的，计数器加一
*/

struct stru
{
    int num;//number
    int q;//quantity
};
int main()
{
    int n;
    scanf("%d",&n);
    struct stru str[n];
    for(int i=0;i<n;i++)
    {
        scanf("%d",&str[i].num);
    }
    //count quantity and assign to q in struct
    for(int i=0;i<n;i++)
    {
        int num=str[i].num;
        while(num!=0)
        {
            int k=num%10;
            if(k=6)
                str[i].q++;
            num/=10;
        }
    }

    //test the change in the struct
    for(int i=0;i<n;i++)
    {
        printf("num = %3d   q = %3d\n",str[i].num,str[i].q);
    }
    return 0;
}
