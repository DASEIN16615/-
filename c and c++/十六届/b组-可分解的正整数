#include <stdio.h>
//数学显出思路

int  main()
{
    int  n;
    scanf("%d", &n);
    int  a[n];
    for (int  i = 0; i < n; i++)
    {
        scanf("%d", &a[i]);
    }
    int counter=0;
    for(int i=0;i<n;i++)
    {
        if(a[i]!=1)
            counter++;
    }
    printf("%d",counter);
    return 0;
}
