#include<stdio.h>
#include<stdlib.h>

void sequenceshift(int *a,int n,int m);
int research(int *a,int n,int x);
void researchandoperation(int *q1,int *q2,int n1,int n2,int x);
void print(int *a,int n);
int isfull(int *a,int n);
int main()
{
    int n1,n2;
    int m;
    scanf("%d %d",&n1,&n2);
    scanf("%d",&m);
    int q1[n1],q2[n2];
    for(int i=0;i<n1;i++)
    {
        q1[i]=-1;
    }
    for(int i=0;i<n2;i++)
    {
        q2[i]=-1;
    }
    int x;
    for(int i=0;i<m;i++)
    {
        scanf("%d",&x);
        researchandoperation(q1,q2,n1,n2,x);
    }
    print(q1,n1);
    print(q2,n2);
    return 0;
}

void researchandoperation(int *q1,int *q2,int n1,int n2,int x)
{
    /*
    查找
        if不在q中
            if q1满 
                if q2满
                    q2数据后移1位,即删掉q2尾部数据
            将 p 移动至 q2 首部
        if在q中
            if在q1中
                if q2满
                    q2数据后移1位,即删掉q2尾部数据
                    q1尾部数据加入q2首部
                q1中在p之前的数据后移1位
                将 p 移动至 q1 首部
            if在q2中
                if q2满
                    q2数据后移1位,即删掉q2尾部数据
                    q1尾部数据加入q2首部
                q2中在p之前的数据后移1位
                将 p 移动至 q1 首部
            
    */
    int i=research(q1,n1,x);
    int j=research(q2,n2,x);
    if(i==-1&&j==-1)
    {
        if(isfull(q1,n1))
        {
            if(isfull(q2,n2))
            {
                sequenceshift(q2,n2,n2-1);
            }
            q2[0]=x;
        }
        else
        {
            sequenceshift(q1,n1,n1-1);
            q2[0]=x;
        }
    }
    else
    {
        if(i!=-1)
        {
            if(isfull(q2,n2))
            {
                sequenceshift(q2,n2,n2-1);
                q2[0]=q1[n1-1];
            }
            for(int k=0;k<=i-1;k--)
            {
                q1[k+1]=q1[k];
            }
            q1[0]=x;
        }
        else
        {
            if(j!=-1)
            {
                if(isfull(q2,n2))
                {
                    sequenceshift(q2,n2,n2-1);
                    q2[0]=q1[n1-1];
                }
                for(int k=0;k<n1;k++)
                {
                    q1[k+1]=q1[k];
                }
                q1[0]=x;
            }
        }
    }
}

//查找函数，找到返回i，没找到返回-1
int research(int *a,int n,int x)
{
    for(int i=0;i<n;i++)
        if(a[i]==x)
            return i;
    return -1;
}

//判断是否满了，满了返回1，没满返回0
int isfull(int *a,int n)
{
    for(int i=0;i<n;i++)
        if(a[i]==-1)
            return 0;
    return 1;
}


void sequenceshift(int *a,int n,int m)
{
    for(int i=0;i<m;i++)
    {
        a[i+1]=a[i];
    }
}

void print(int *a,int n)
{
    for(int i=0;i<n;i++)
    {
        if(a[i]!=-1)
        printf("%d ",a[i]);
    }
    printf("\n");
}
