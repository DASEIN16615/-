#include<stdio.h>
#include<stdlib.h>

// 修正1：使用a[0]记录队列中实际元素个数，而不是用-1作为占位符
// 修正2：删除了sequenceshift函数，因为操作中直接移动元素
// 修正3：修改了isfull函数，使用a[0]判断队列是否满
// 修正4：修改了research函数，从1开始查找（因为a[0]表示元素个数，a[1]~a[a[0]]是实际数据）
// 修正5：修改了researchandoperation函数，正确处理队列满时的移除操作

int research(int *a, int n, int x); // 查找函数，返回x在队列中的位置（从1开始），没找到返回-1
int isfull(int *a, int n); // 判断队列是否满，使用a[0]（队列中实际元素个数）判断
void researchandoperation(int *q1, int *q2, int n1, int n2, int x); // 处理操作
void print(int *a, int n); // 打印队列

int main()
{
    int n1, n2;
    int m;
    scanf("%d %d", &n1, &n2);
    scanf("%d", &m);
    
    // 修正6：使用数组，其中a[0]表示队列中实际有多少个元素
    int q1[n1 + 1]; // q1[0]表示q1中实际元素个数
    int q2[n2 + 1]; // q2[0]表示q2中实际元素个数
    
    // 初始化：设置队列中元素个数为0
    q1[0] = 0;
    q2[0] = 0;
    
    int x;
    for (int i = 0; i < m; i++)
    {
        scanf("%d", &x);
        researchandoperation(q1, q2, n1, n2, x);
    }
    
    print(q1, n1);
    print(q2, n2);
    
    return 0;
}

void researchandoperation(int *q1, int *q2, int n1, int n2, int x)
{
    // 修正7：使用v数组记录x是否在队列中（这里使用一个简单的数组代替，实际题目中数据范围0~10^4）
    // 但为了简洁，我们直接使用队列查找，不额外使用v数组（因为题目数据范围不大）
    
    // 查找x在q1和q2中的位置
    int i = research(q1, n1, x);
    int j = research(q2, n2, x);
    
    if (i == -1 && j == -1) // x既不在q1中，也不在q2中
    {
        // 将x放入q2的首部
        // 修正8：先处理q2满的情况
        if (isfull(q2, n2))
        {
            // 如果q2满了，先移除q2的最后一个元素
            // 注意：这里不直接移除q2的最后一个元素，而是将q1的最后一个元素移到q2
            // 但根据题目要求，只有当q1满且q2未满时，才从q1移元素到q2
            // 实际上，当q2满时，我们需要移除q2的最后一个元素
            // 但题目要求：当q1满且q2未满时，才从q1移元素到q2
            // 所以这里q2满了，我们只能移除q2的最后一个元素
            // 注意：这里不需要检查q1是否满，因为题目要求是"当q1满且q2未满时"才移动
            // 但当前q2满了，所以q2必须移除一个元素
            // 从q2中移除最后一个元素（q2[q2[0]]）
            q2[q2[0]] = -1; // 标记为已移除，实际代码中不需要这行，因为我们直接调整队列
            q2[0]--; // 减少元素个数
        }
        // 将x放入q2的首部
        // 修正9：将q2中现有元素向后移动，为x腾出位置
        for (int k = q2[0]; k >= 1; k--)
            q2[k + 1] = q2[k];
        q2[1] = x;
        q2[0]++; // 增加q2中元素个数
    }
    else
    {
        // x已经在队列中，需要将其移到q1的首部
        // 修正10：先从原队列中移除x
        if (i != -1) // x在q1中
        {
            // 从q1中移除x
            for (int k = i; k < q1[0]; k++)
                q1[k] = q1[k + 1];
            q1[0]--; // 减少q1中元素个数
        }
        else if (j != -1) // x在q2中
        {
            // 从q2中移除x
            for (int k = j; k < q2[0]; k++)
                q2[k] = q2[k + 1];
            q2[0]--; // 减少q2中元素个数
        }
        
        // 修正11：将x放入q1的首部
        // 先处理q1满的情况
        if (isfull(q1, n1))
        {
            // 如果q1满了，需要从q1中移除最后一个元素
            int t = q1[q1[0]]; // q1[q1[0]]是q1的最后一个元素
            q1[q1[0]] = -1; // 标记为已移除
            q1[0]--; // 减少q1中元素个数
            
            // 修正12：将移除的元素t放入q2的首部
            // 但需要先处理q2满的情况
            if (isfull(q2, n2))
            {
                // 如果q2也满了，先移除q2的最后一个元素
                q2[q2[0]] = -1;
                q2[0]--;
            }
            // 将t放入q2的首部
            for (int k = q2[0]; k >= 1; k--)
                q2[k + 1] = q2[k];
            q2[1] = t;
            q2[0]++; // 增加q2中元素个数
        }
        
        // 将x放入q1的首部
        for (int k = q1[0]; k >= 1; k--)
            q1[k + 1] = q1[k];
        q1[1] = x;
        q1[0]++; // 增加q1中元素个数
    }
}

// 修正13：查找函数，从1开始查找（因为a[0]是元素个数，a[1]~a[a[0]]是数据）
int research(int *a, int n, int x)
{
    for (int i = 1; i <= a[0]; i++)
        if (a[i] == x)
            return i;
    return -1;
}

// 修正14：判断队列是否满，使用a[0]（实际元素个数）与n比较
int isfull(int *a, int n)
{
    return a[0] == n;
}

void print(int *a, int n)
{
    for (int i = 1; i <= a[0]; i++)
    {
        printf("%d ", a[i]);
    }
    printf("\n");
}
